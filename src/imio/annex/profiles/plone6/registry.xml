<?xml version="1.0"?>
<registry>

  <!-- types_use_view_action_in_listings (replaces propertiestool.xml) -->
  <record field="types_use_view_action_in_listings"
          interface="plone.base.interfaces.controlpanel.ITypesSchema"
          name="plone.types_use_view_action_in_listings"
          purge="false">
    <value>
      <element>annex</element>
    </value>
  </record>

  <!-- Resource bundle (replaces cssregistry.xml + jsregistry.xml) -->
  <records interface="Products.CMFPlone.interfaces.IBundleRegistry"
           prefix="plone.bundles/imio.annex.base">
    <value key="enabled">True</value>
    <value key="depends">plone</value>
    <value key="jscompilation">++resource++imio.annex.quickupload/helpers.js</value>
    <value key="csscompilation">++resource++imio.annex.quickupload/quickupload.css</value>
    <value key="expression" />
    <value key="load_async">False</value>
    <value key="load_defer">False</value>
  </records>

</registry>
